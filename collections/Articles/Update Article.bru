meta {
  name: Update Article
  type: http
  seq: 4
}

post {
  url: {{base_url}}/articles/1
  body: multipartForm
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  title: Updated Title
  image: data:image/png;base64,
  content: This is an updated content.
}

settings {
  encodeUrl: true
}
