meta {
  name: Update User Password
  type: http
  seq: 4
}

put {
  url: {{base_url}}/users/1/change-password
  body: json
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "current_password": "OldPass123!",
      "new_password": "NewStrongPass!1",
      "new_password_confirmation": "NewStrongPass!1"
  }
}

settings {
  encodeUrl: true
}
