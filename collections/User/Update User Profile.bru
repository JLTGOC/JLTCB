meta {
  name: Update User Profile
  type: http
  seq: 5
}

post {
  url: {{base_url}}/users/1/change-profile
  body: multipartForm
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  image: data:image/jpeg;base64,
}

settings {
  encodeUrl: true
}
