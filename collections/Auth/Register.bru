meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{base_url}}/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
}

body:json {
  {
      "email": "example@gmail.com",
      "password": "guest",
      "firstName": "test",
      "lastName": "tester",
      "address": "AC",
      "contactNumber": "09667481056"
  }
}

settings {
  encodeUrl: true
}
